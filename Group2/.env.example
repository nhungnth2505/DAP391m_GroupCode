# Student Guidance Dashboard - Environment Configuration
# Copy this file to .env and fill in your values
# Windows: copy .env.example .env

# LLM Provider: openai, nvidia, groq, azure, ollama
LLM_PROVIDER=nvidia

# API Key for your LLM provider
LLM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxx

# Model to use (NVIDIA models for nvidia provider)
LLM_MODEL=nvidia/mistral-nemo-mini-instruct

# OpenAI compatible endpoint (usually default is fine)
# LLM_API_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions

# Flask secret key (change this for production)
SECRET_KEY=dev-student-dashboard-2024